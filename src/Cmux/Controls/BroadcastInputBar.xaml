<UserControl x:Class="Cmux.Controls.BroadcastInputBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Cmux.ViewModels">

    <UserControl.Resources>
        <!--
            Local dark template overrides for the broadcast bar's ComboBox.
            The Aero default the system ships paints the highlighted /
            selected ComboBoxItem with a bright blue/white pair that's
            unreadable on the cmuxw dark surface. Re-templating only inside
            this control scope avoids regressing other dialogs (Settings,
            Editor folder picker) that already work with their own styles.
        -->
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarItemHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarItemSelectedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}" />
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press" Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="{TemplateBinding Padding}"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center" />
                                                <Path Grid.Column="1" Width="8" Height="5" Margin="0,0,8,0"
                                                      VerticalAlignment="Center"
                                                      Fill="{StaticResource ForegroundDimBrush}"
                                                      Data="M 0 0 L 8 0 L 4 5 Z" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter
                                IsHitTestVisible="False"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"
                                TextElement.Foreground="{StaticResource ForegroundBrush}" />
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True"
                                   PopupAnimation="None" Focusable="False">
                                <Border Background="#FF141420"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="320"
                                        CornerRadius="4" SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.4" Color="Black" />
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,1"
            Padding="8,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Broadcast icon -->
            <TextBlock Grid.Column="0" Text="&#xE95A;" FontFamily="Segoe MDL2 Assets"
                       FontSize="13" Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center" Margin="2,0,8,0" />

            <TextBlock Grid.Column="1" Text="Broadcast" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource ForegroundBrush}"
                       VerticalAlignment="Center" Margin="0,0,10,0" />

            <!-- Scope selector -->
            <ComboBox Grid.Column="2" Width="200" Height="28"
                      Style="{StaticResource DarkComboBox}"
                      SelectedValuePath="Tag"
                      SelectedValue="{Binding Scope}"
                      Margin="0,0,6,0">
                <ComboBoxItem Tag="{x:Static vm:BroadcastScope.CurrentSurface}" Style="{StaticResource DarkComboBoxItem}">
                    현재 터미널 (모든 Pane)
                </ComboBoxItem>
                <ComboBoxItem Tag="{x:Static vm:BroadcastScope.Workspace}" Style="{StaticResource DarkComboBoxItem}">
                    워크스페이스 전체
                </ComboBoxItem>
                <ComboBoxItem Tag="{x:Static vm:BroadcastScope.Selected}" Style="{StaticResource DarkComboBoxItem}">
                    선택한 Panes (직접 체크)
                </ComboBoxItem>
                <ComboBoxItem Tag="{x:Static vm:BroadcastScope.ClaudeAll}" Style="{StaticResource DarkComboBoxItem}">
                    Claude 세션 (모두)
                </ComboBoxItem>
                <ComboBoxItem Tag="{x:Static vm:BroadcastScope.ClaudeLocal}" Style="{StaticResource DarkComboBoxItem}">
                    Claude 세션 (로컬)
                </ComboBoxItem>
                <ComboBoxItem Tag="{x:Static vm:BroadcastScope.ClaudeSsh}" Style="{StaticResource DarkComboBoxItem}">
                    Claude 세션 (SSH)
                </ComboBoxItem>
            </ComboBox>

            <!-- Pane picker (popup) -->
            <ToggleButton Grid.Column="3" x:Name="PanePickerToggle" Height="28"
                          Padding="8,0" Margin="0,0,6,0"
                          Background="{StaticResource InputBackgroundBrush}"
                          Foreground="{StaticResource ForegroundBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          BorderThickness="1" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="Panes" VerticalAlignment="Center" FontSize="11" />
                </StackPanel>
            </ToggleButton>

            <Popup IsOpen="{Binding IsChecked, ElementName=PanePickerToggle, Mode=TwoWay}"
                   PlacementTarget="{Binding ElementName=PanePickerToggle}"
                   Placement="Top" StaysOpen="False" AllowsTransparency="True">
                <Border Background="#FF141420"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="8" MinWidth="280" MaxHeight="380">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.4" Color="Black" />
                    </Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Send to selected panes (선택한 Panes 모드)"
                                   Foreground="{StaticResource ForegroundDimBrush}"
                                   FontSize="10" Margin="2,0,2,8" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding SurfaceGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2,0,8">
                                            <!-- Surface (terminal) header -->
                                            <Border Background="#FF1A1A2E" CornerRadius="3" Padding="6,3" Margin="0,0,0,3">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="10" Margin="0,0,5,0"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding SurfaceName}"
                                                               Foreground="{StaticResource ForegroundBrush}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <!-- Panes inside this surface -->
                                            <ItemsControl ItemsSource="{Binding Panes}" Margin="14,0,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Content="{Binding Label}"
                                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                                  Style="{StaticResource DarkCheckBox}"
                                                                  Margin="2,3" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Popup>

            <!-- Preset prompts (popup) — natural language commands for Claude broadcast -->
            <ToggleButton Grid.Column="4" x:Name="PresetToggle" Height="28"
                          Padding="8,0" Margin="0,0,8,0"
                          Background="{StaticResource InputBackgroundBrush}"
                          Foreground="{StaticResource ForegroundBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          BorderThickness="1" Cursor="Hand"
                          ToolTip="자주 쓰는 자연어 명령 (broadcast-presets.json)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="프리셋" VerticalAlignment="Center" FontSize="11" />
                </StackPanel>
            </ToggleButton>

            <Popup IsOpen="{Binding IsChecked, ElementName=PresetToggle, Mode=TwoWay}"
                   PlacementTarget="{Binding ElementName=PresetToggle}"
                   Placement="Top" StaysOpen="False" AllowsTransparency="True">
                <Border Background="#FF141420"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="6" MinWidth="320" MaxHeight="320">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.4" Color="Black" />
                    </Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="클릭하면 입력창에 채워집니다 (Send로 전송)"
                                   Foreground="{StaticResource ForegroundDimBrush}"
                                   FontSize="10" Margin="4,2,4,6" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Presets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Foreground="{StaticResource ForegroundBrush}"
                                                Padding="8,6" Margin="0" Cursor="Hand"
                                                Click="PresetItem_Click"
                                                Tag="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Stretch" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SidebarItemHoverBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Label}" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource ForegroundBrush}" />
                                                <TextBlock Text="{Binding Text}" FontSize="10"
                                                           Foreground="{StaticResource ForegroundDimBrush}"
                                                           TextWrapping="Wrap" Margin="0,2,0,0"
                                                           Opacity="0.85" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Popup>

            <!-- Input box -->
            <TextBox Grid.Column="5" x:Name="InputBox" Height="28"
                     Background="{StaticResource InputBackgroundBrush}"
                     Foreground="{StaticResource ForegroundBrush}"
                     CaretBrush="{StaticResource AccentBrush}"
                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                     Padding="8,4" VerticalContentAlignment="Center"
                     FontFamily="Cascadia Mono, Consolas"
                     Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                     PreviewKeyDown="InputBox_PreviewKeyDown" />

            <!-- Target count -->
            <TextBlock Grid.Column="6" Text="{Binding TargetSummary}"
                       Foreground="{StaticResource ForegroundDimBrush}"
                       FontSize="10" VerticalAlignment="Center"
                       Margin="10,0,8,0" />

            <!-- Send button -->
            <Button Grid.Column="7" Style="{StaticResource CmuxButton}"
                    Padding="12,4" FontSize="11" Margin="0,0,4,0"
                    Foreground="{StaticResource ForegroundBrush}"
                    Background="{StaticResource SidebarItemSelectedBrush}"
                    Command="{Binding SubmitCommand}"
                    ToolTip="Send (Enter)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,5,0" />
                    <TextBlock Text="Send" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Close -->
            <Button Grid.Column="8" Style="{StaticResource IconButton}"
                    Command="{Binding HideCommand}"
                    ToolTip="Close (Esc)">
                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
            </Button>
        </Grid>
    </Border>
</UserControl>
