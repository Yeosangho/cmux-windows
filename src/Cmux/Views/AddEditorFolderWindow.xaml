<Window x:Class="Cmux.Views.AddEditorFolderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Folder" Height="480" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Add Folder to Editor"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource ForegroundBrush}" />

        <!-- Kind selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,8">
            <RadioButton x:Name="LocalRadio" Content="Local folder" GroupName="Kind"
                         IsChecked="True" Foreground="{StaticResource ForegroundBrush}"
                         Margin="0,0,16,0" Checked="KindChanged" />
            <RadioButton x:Name="RemoteRadio" Content="Remote (SSH)" GroupName="Kind"
                         Foreground="{StaticResource ForegroundBrush}"
                         Checked="KindChanged" />
        </StackPanel>

        <!-- Form -->
        <Grid Grid.Row="2">
            <!-- Local form -->
            <StackPanel x:Name="LocalForm">
                <TextBlock Text="Folder path" Foreground="{StaticResource ForegroundDimBrush}" />
                <Grid Margin="0,4,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="LocalPathBox" Grid.Column="0"
                             Background="{StaticResource InputBackgroundBrush}"
                             Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             Padding="6,4" />
                    <Button Grid.Column="1" Content="Browse..." Margin="6,0,0,0"
                            Padding="10,4" Style="{StaticResource CmuxButton}"
                            Click="BrowseLocal_Click" />
                </Grid>

                <TextBlock Text="Display name (optional)" Foreground="{StaticResource ForegroundDimBrush}" />
                <TextBox x:Name="LocalDisplayNameBox" Margin="0,4,0,0"
                         Background="{StaticResource InputBackgroundBrush}"
                         Foreground="{StaticResource ForegroundBrush}"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                         Padding="6,4" />
            </StackPanel>

            <!-- Remote form -->
            <StackPanel x:Name="RemoteForm" Visibility="Collapsed">
                <TextBlock Text="From SSH config" Foreground="{StaticResource ForegroundDimBrush}" />
                <ComboBox x:Name="SshConfigCombo" Margin="0,4,0,8"
                          Background="{StaticResource InputBackgroundBrush}"
                          Foreground="{StaticResource ForegroundBrush}"
                          BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                          Padding="6,4"
                          SelectionChanged="SshConfigCombo_SelectionChanged" />

                <TextBlock x:Name="SshConfigInfoText"
                           Text="Using ssh_config - sftp.exe will read user/port/identity from your ~/.ssh/config"
                           Foreground="{StaticResource ForegroundDimBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,8"
                           Visibility="Collapsed" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Host" Foreground="{StaticResource ForegroundDimBrush}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Port" Foreground="{StaticResource ForegroundDimBrush}" Margin="6,0,0,0" />

                    <TextBox x:Name="HostBox" Grid.Row="1" Grid.Column="0"
                             Background="{StaticResource InputBackgroundBrush}"
                             Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             Padding="6,4" Margin="0,4,0,8" />
                    <TextBox x:Name="PortBox" Grid.Row="1" Grid.Column="1" Text="22"
                             Background="{StaticResource InputBackgroundBrush}"
                             Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             Padding="6,4" Margin="6,4,0,8" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="Username"
                               Foreground="{StaticResource ForegroundDimBrush}" />
                    <TextBox x:Name="UsernameBox" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                             Background="{StaticResource InputBackgroundBrush}"
                             Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             Padding="6,4" Margin="0,4,0,8" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Text="Remote path"
                               Foreground="{StaticResource ForegroundDimBrush}" />
                    <TextBox x:Name="RemotePathBox" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                             Background="{StaticResource InputBackgroundBrush}"
                             Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             Padding="6,4" Margin="0,4,0,8" Text="/" />

                    <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Text="Authentication"
                               Foreground="{StaticResource ForegroundDimBrush}" />
                    <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,8">
                        <RadioButton x:Name="PasswordAuthRadio" Content="Password" GroupName="Auth"
                                     IsChecked="True" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,16,0" />
                        <RadioButton x:Name="KeyAuthRadio" Content="Private key" GroupName="Auth"
                                     Foreground="{StaticResource ForegroundBrush}" />
                    </StackPanel>

                    <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                               Foreground="{StaticResource ForegroundDimBrush}">
                        <Run Text="Password / Key passphrase" />
                    </TextBlock>
                    <PasswordBox x:Name="PasswordBox" Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 Foreground="{StaticResource ForegroundBrush}"
                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                 Padding="6,4" Margin="0,4,0,8" />
                </Grid>

                <TextBlock Text="Private key path (optional)" Foreground="{StaticResource ForegroundDimBrush}" />
                <Grid Margin="0,4,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="KeyPathBox" Grid.Column="0"
                             Background="{StaticResource InputBackgroundBrush}"
                             Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             Padding="6,4" />
                    <Button Grid.Column="1" Content="Browse..." Margin="6,0,0,0"
                            Padding="10,4" Style="{StaticResource CmuxButton}"
                            Click="BrowseKey_Click" />
                </Grid>

                <TextBlock Text="Display name (optional)" Foreground="{StaticResource ForegroundDimBrush}" />
                <TextBox x:Name="RemoteDisplayNameBox" Margin="0,4,0,0"
                         Background="{StaticResource InputBackgroundBrush}"
                         Foreground="{StaticResource ForegroundBrush}"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                         Padding="6,4" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Padding="14,5" Margin="0,0,8,0"
                    Style="{StaticResource CmuxButton}" Click="Cancel_Click" />
            <Button Content="Add" Padding="14,5"
                    Style="{StaticResource AccentButton}" Click="Add_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
